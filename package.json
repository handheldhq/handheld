{
  "name": "handheld",
  "version": "0.1.0",
  "description": "Real cloud phones for AI agents — Handheld CLI and MCP server",
  "license": "MIT",
  "author": "Bruce Weaver <hbw@lattice.sh>",
  "homepage": "https://mobileuse.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbruceweaver/mobileuse.git"
  },
  "bugs": {
    "url": "https://github.com/hbruceweaver/mobileuse/issues"
  },
  "keywords": [
    "mobile",
    "android",
    "agent",
    "ai",
    "cloud",
    "mcp",
    "browser-use",
    "device-cloud",
    "automation"
  ],
  "type": "module",
  "bin": {
    "handheld": "./dist/cli.js",
    "handheld-route": "./dist/route-cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "android/tiny-snapshot-helper-v2",
    "assets",
    "dist",
    "scripts/build-tiny-v2-helper.sh"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:tiny": "sh scripts/build-tiny-v2-helper.sh",
    "build:tiny:v2": "sh scripts/build-tiny-v2-helper.sh",
    "dev": "tsup --watch",
    "clean": "git clean -xdf .turbo dist node_modules",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.3",
    "ssh2": "^1.17.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
